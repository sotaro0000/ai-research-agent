# ── AI Research Agent 環境変数（すべて任意）──────────────────
# このアプリは「利用者が各自のAPIキーを画面で入力する方式（BYOK）」が基本です。
# 以下の環境変数は、運営側で共通キーを使いたい場合の“任意のフォールバック”です。
# 通常は設定不要（未設定でもデモが動き、利用者がUIでキーを入力すれば本格モードになります）。

# ── LLM（設定すると、知識ベースでのレポート生成が有効に）──
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Web検索（LLMキーに加えて設定すると、本物のWeb調査＋出典付きに）──
# SEARCH_PROVIDER: "tavily" または "serper"
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=
