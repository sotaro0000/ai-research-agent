# ── AI Research Agent 環境変数（すべて任意）──────────────────
# 何も設定しなくても「デモモード」で動作します。
# キーを設定すると段階的に本格化します。

# ── LLM（設定すると、知識ベースでのレポート生成が有効に）──
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Web検索（LLMキーに加えて設定すると、本物のWeb調査＋出典付きに）──
# SEARCH_PROVIDER: "tavily" または "serper"
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=
